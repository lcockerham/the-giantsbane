---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const tagCounts = allPosts.reduce<Record<string, number>>((acc, post) => {
  for (const tag of post.data.tags) {
    acc[tag] = (acc[tag] ?? 0) + 1;
  }
  return acc;
}, {});

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags">
  <h1 class="font-cinzel text-3xl font-bold text-gold mb-8">Tags</h1>

  <div class="flex flex-wrap gap-3">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${tag.toLowerCase()}`}
        class="font-cinzel text-sm border border-stone-600 px-3 py-1.5 rounded text-gold hover:border-gold hover:bg-stone-800 transition-colors flex items-center gap-2"
      >
        {tag}
        <span class="text-parchment/50 text-xs">{count}</span>
      </a>
    ))}
  </div>
</BaseLayout>
