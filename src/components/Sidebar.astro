      DMing since 1997. Platinum author on DM's Guild.
    </p>
  </div>

  <div>
    <h3 class="font-cinzel text-xs tracking-widest uppercase text-crimson border-b border-pit-600 pb-2 mb-4">Tags</h3>
    <div class="flex flex-wrap gap-2">
      {topTags.map(([tag, count]) => (
        <a
          href={`/tags/${tag.toLowerCase()}`}
          class="font-cinzel text-xs tracking-wide bg-pit-800 border border-pit-600 px-2 py-1 text-dim hover:text-crimson hover:border-crimson-dark transition-colors"
